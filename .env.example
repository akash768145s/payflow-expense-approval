# ============================================
# PayFlow - Environment Configuration
# ============================================

# Application
PORT=3000
NODE_ENV=production

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=hello
POSTGRES_DB=payflow

# Backend connects to the PostgreSQL Docker service named "db"
DATABASE_URL=postgresql://postgres:hello@db:5432/payflow?schema=public

# Authentication
COOKIE_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Frontend (optional)
VITE_API_URL=http://localhost:3000